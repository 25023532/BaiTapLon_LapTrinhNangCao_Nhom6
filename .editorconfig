# EditorConfig — AuctionSystem_Nhom6
# https://editorconfig.org

root = true

# ── Toàn bộ file ─────────────────────────────────────────────────────────
[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 4

# ── Java ─────────────────────────────────────────────────────────────────
[*.java]
indent_style = space
indent_size  = 4
max_line_length = 120

# ── XML (pom.xml, checkstyle.xml, FXML) ──────────────────────────────────
[*.xml]
indent_style = space
indent_size  = 4

# ── YAML (GitHub Actions workflows) ──────────────────────────────────────
[*.{yml,yaml}]
indent_style = space
indent_size  = 2

# ── Markdown ─────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length          = off

# ── Properties ───────────────────────────────────────────────────────────
[*.properties]
indent_style = space
indent_size  = 2

# ── JSON ─────────────────────────────────────────────────────────────────
[*.json]
indent_style = space
indent_size  = 2
