<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.nhom6.auctionsystem_nhom6.AdminController"
            styleClass="main-root">

    <!-- ── SIDEBAR ── -->
    <left>
        <VBox styleClass="sidebar" spacing="4">
            <padding><Insets top="20" right="12" bottom="20" left="12"/></padding>

            <VBox styleClass="sidebar-logo" spacing="2">
                <padding><Insets bottom="20"/></padding>
                <Label text="🏛" styleClass="logo-icon"/>
                <Label text="AuctionSys" styleClass="logo-name"/>
                <Label text="Quản trị hệ thống" styleClass="logo-sub"/>
            </VBox>

            <Label text="QUẢN LÝ" styleClass="cat-title"/>
            <Button fx:id="btnUsers"    text="👥  Người dùng"    maxWidth="Infinity"
                    styleClass="nav-btn" onAction="#showUsers"/>
            <Button fx:id="btnProducts" text="📦  Sản phẩm"      maxWidth="Infinity"
                    styleClass="nav-btn" onAction="#showProducts"/>
            <Button fx:id="btnSessions" text="🔴  Phiên đấu giá" maxWidth="Infinity"
                    styleClass="nav-btn" onAction="#showSessions"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Đăng xuất giữ lại ở sidebar để tiện -->
            <Button text="← Đăng xuất" maxWidth="Infinity"
                    styleClass="btn-danger" onAction="#handleLogout"/>
        </VBox>
    </left>

    <!-- ── MAIN CONTENT ── -->
    <center>
        <VBox spacing="0">

            <!-- Header với profile dropdown -->
            <HBox styleClass="header" alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>
                <Label text="🛡 Bảng điều khiển Admin" styleClass="header-username"/>
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Profile dropdown giống Seller -->
                <MenuButton fx:id="adminMenuBtn" styleClass="profile-menu-btn">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER">
                            <Label fx:id="adminAvatarLabel" styleClass="profile-avatar"/>
                            <VBox alignment="CENTER_LEFT">
                                <Label fx:id="adminNameLabel" styleClass="header-username"/>
                                <Label text="ADMIN" styleClass="header-role"/>
                            </VBox>
                        </HBox>
                    </graphic>
                    <items>
                        <MenuItem text="👤  Hồ sơ"     onAction="#handleProfile"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="🚪  Đăng xuất" onAction="#handleLogout"/>
                    </items>
                </MenuButton>

            </HBox>

            <!-- Stat cards -->
            <HBox spacing="16">
                <padding><Insets top="20" right="24" bottom="0" left="24"/></padding>

                <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="👥 Tổng người dùng" styleClass="stat-big-label"/>
                    <Label fx:id="totalUsersLabel" text="0" styleClass="stat-big-num"/>
                </VBox>

                <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="📦 Tổng sản phẩm" styleClass="stat-big-label"/>
                    <Label fx:id="totalProductsLabel" text="0" styleClass="stat-big-num"/>
                </VBox>

                <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="⏳ Chờ duyệt" styleClass="stat-big-label"/>
                    <Label fx:id="pendingLabel" text="0" styleClass="stat-big-num"/>
                </VBox>

                <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="🔴 Đang đấu giá" styleClass="stat-big-label"/>
                    <Label fx:id="activeSessionsLabel" text="0" styleClass="stat-big-num"/>
                </VBox>
            </HBox>

            <!-- Tab bar -->
            <HBox fx:id="tabBar" styleClass="tab-bar" spacing="4">
                <padding><Insets top="20" right="24" bottom="0" left="24"/></padding>
                <Button text="👥 Người dùng"    styleClass="tab-btn,tab-active"
                        onAction="#showUsers"/>
                <Button text="📦 Sản phẩm"      styleClass="tab-btn"
                        onAction="#showProducts"/>
                <Button text="🔴 Phiên đấu giá" styleClass="tab-btn"
                        onAction="#showSessions"/>
            </HBox>

            <!-- Content area -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        styleClass="profile-scroll">
                <VBox fx:id="contentBox" spacing="10">
                    <padding><Insets top="16" right="24" bottom="24" left="24"/></padding>
                </VBox>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
