<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.nhom6.auctionsystem_nhom6.controller.MyProductsController"
            stylesheets="@../styles/main.css"
            styleClass="main-root">

    <!-- ══ SIDEBAR ══ -->
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <HBox styleClass="sidebar-logo" spacing="15" alignment="CENTER_LEFT">
                <padding><Insets top="25" right="16" bottom="25" left="16"/></padding>
                <ImageView fitWidth="55" fitHeight="55" preserveRatio="true" smooth="true">
                    <image><Image url="@../images/logo.png"/></image>
                </ImageView>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="AuctionSys"       styleClass="logo-name"/>
                    <Label text="Hệ thống đấu giá" styleClass="logo-sub"/>
                </VBox>
            </HBox>

            <VBox styleClass="sidebar-nav" spacing="2">
                <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                <Button text="⊞  Tổng quan"         maxWidth="Infinity" styleClass="nav-btn" onAction="#handleBack"/>
                <Button text="☰  Danh sách phiên"    maxWidth="Infinity" styleClass="nav-btn" onAction="#handleAuctionList"/>
                <Button text="⚡  Đấu giá trực tiếp"  maxWidth="Infinity" styleClass="nav-btn" onAction="#handleLiveAuction"/>
                <Button fx:id="btnSellerProducts"   text="📦  Sản phẩm của tôi" maxWidth="Infinity" styleClass="nav-btn,nav-active" onAction="#handleSellerProducts"/>
                <Button fx:id="btnAdminProducts"    text="🛠  Quản lý sản phẩm" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleAdminProducts" visible="false" managed="false"/>
                <Button text="💳  Ví &amp; Giao dịch" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleWallet"/>
                <Button text="★  Đánh giá"           maxWidth="Infinity" styleClass="nav-btn" onAction="#handleRating"/>
                <Button text="?  Trợ giúp"            maxWidth="Infinity" styleClass="nav-btn" onAction="#handleHelp"/>
            </VBox>

            <VBox styleClass="sidebar-cats" spacing="2">
                <padding><Insets top="8" right="8" bottom="8" left="16"/></padding>
                <Label text="DANH MỤC" styleClass="cat-title"/>
                <Button text="🖥️  Điện tử"    maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDienTu"/>
                <Button text="📷  Máy ảnh"    maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryMayAnh"/>
                <Button text="💻  Laptop"     maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryLaptop"/>
                <Button text="📱  Điện thoại" maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDienThoai"/>
                <Button text="⌚  Đồng hồ"   maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDongHo"/>
                <Button text="🚗  Xe cộ"     maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryXeCo"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- ══ HEADER ══ -->
    <top>
        <HBox styleClass="header" spacing="15" alignment="CENTER_LEFT"
              style="-fx-background-color: #1F0C40; -fx-border-color: #1A1A1A; -fx-border-width: 0 0 4 0;">
            <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
            <Button text="← QUAY LẠI" onAction="#handleBack" styleClass="btn-secondary"
                    style="-fx-background-color: #FFFFFF; -fx-text-fill: #1A1A1A; -fx-font-weight: 900; -fx-border-color: #1A1A1A; -fx-border-width: 3; -fx-background-radius: 0;"/>
            <Label text="SẢN PHẨM ĐĂNG BÁN" styleClass="header-username"
                   style="-fx-text-fill: #FFFFFF; -fx-font-weight: 900; -fx-letter-spacing: 2px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="statusFilter" promptText="Tất cả trạng thái"
                      styleClass="filter-combo" onAction="#handleFilter"
                      style="-fx-background-color: #FFFFFF; -fx-border-color: #1A1A1A; -fx-border-width: 3; -fx-background-radius: 0;"/>
            <TextField fx:id="searchField" promptText="Tìm sản phẩm..."
                       prefWidth="220" styleClass="search-field"
                       onKeyReleased="#handleSearch"
                       style="-fx-background-color: #FFFFFF; -fx-border-color: #1A1A1A; -fx-border-width: 3; -fx-background-radius: 0;"/>
            <Button text="＋  ĐĂNG BÁN MỚI" onAction="#handleAddProduct"
                    styleClass="btn-primary"
                    style="-fx-background-color: #FF6B35; -fx-text-fill: #FFFFFF; -fx-font-weight: 900; -fx-border-color: #1A1A1A; -fx-border-width: 3; -fx-background-radius: 0; -fx-effect: dropshadow(one-pass-box, #1A1A1A, 0, 0, 3, 3);"/>
            <Button text="⚡  BẮT ĐẦU TẤT CẢ" onAction="#handleStartAll"
                    styleClass="btn-primary"
                    style="-fx-background-color: #22C55E; -fx-text-fill: #FFFFFF; -fx-font-weight: 900; -fx-border-color: #1A1A1A; -fx-border-width: 3; -fx-background-radius: 0; -fx-effect: dropshadow(one-pass-box, #1A1A1A, 0, 0, 3, 3);"/>
        </HBox>
    </top>

    <!-- ══ CONTENT ══ -->
    <center>
        <VBox styleClass="content-area" spacing="20" style="-fx-background-color: #FFF8F0;">
            <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

            <!-- Thống kê -->
            <HBox spacing="20">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="5"
                      style="-fx-background-color: #FFFFFF; -fx-border-color: #1A1A1A; -fx-border-width: 4; -fx-effect: dropshadow(one-pass-box, #1A1A1A, 0, 0, 6, 6);">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <Label fx:id="totalProductsLabel" text="0" styleClass="stat-big-num" style="-fx-text-fill: #1F0C40; -fx-font-weight: 900;"/>
                    <Label text="TỔNG SẢN PHẨM" styleClass="stat-big-label" style="-fx-text-fill: #1A1A1A; -fx-font-weight: 900; -fx-font-size: 10px;"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="5"
                      style="-fx-background-color: #FFFFFF; -fx-border-color: #1A1A1A; -fx-border-width: 4; -fx-effect: dropshadow(one-pass-box, #1A1A1A, 0, 0, 6, 6);">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <Label fx:id="activeProductsLabel" text="0" styleClass="stat-big-num" style="-fx-text-fill: #22C55E; -fx-font-weight: 900;"/>
                    <Label text="ĐANG ĐẤU GIÁ" styleClass="stat-big-label" style="-fx-text-fill: #1A1A1A; -fx-font-weight: 900; -fx-font-size: 10px;"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="5"
                      style="-fx-background-color: #FFFFFF; -fx-border-color: #1A1A1A; -fx-border-width: 4; -fx-effect: dropshadow(one-pass-box, #1A1A1A, 0, 0, 6, 6);">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <Label fx:id="soldProductsLabel" text="0" styleClass="stat-big-num" style="-fx-text-fill: #FF6B35; -fx-font-weight: 900;"/>
                    <Label text="ĐÃ BÁN" styleClass="stat-big-label" style="-fx-text-fill: #1A1A1A; -fx-font-weight: 900; -fx-font-size: 10px;"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="5"
                      style="-fx-background-color: #FFFFFF; -fx-border-color: #1A1A1A; -fx-border-width: 4; -fx-effect: dropshadow(one-pass-box, #1A1A1A, 0, 0, 6, 6);">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <Label fx:id="revenueLabel" text="₫ 0" styleClass="stat-big-num" style="-fx-text-fill: #3B82F6; -fx-font-weight: 900;"/>
                    <Label text="DOANHTHU" styleClass="stat-big-label" style="-fx-text-fill: #1A1A1A; -fx-font-weight: 900; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <!-- Danh sách sản phẩm -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="bid-scroll">
                <VBox fx:id="productListBox" spacing="10">
                    <padding><Insets top="8" right="0" bottom="8" left="0"/></padding>
                </VBox>
            </ScrollPane>

        </VBox>
    </center>
</BorderPane>
