<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.nhom6.auctionsystem_nhom6.controller.HelpController"
            styleClass="main-root">

    <!-- ══ SIDEBAR ══ -->
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <HBox styleClass="sidebar-logo" spacing="15" alignment="CENTER_LEFT">
                <padding><Insets top="25" right="16" bottom="25" left="16"/></padding>
                <ImageView fitWidth="55" fitHeight="55" preserveRatio="true" smooth="true">
                    <image><Image url="@../images/logo.png"/></image>
                </ImageView>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="AuctionSys"       styleClass="logo-name"/>
                    <Label text="Hệ thống đấu giá" styleClass="logo-sub"/>
                </VBox>
            </HBox>

            <VBox styleClass="sidebar-nav" spacing="2">
                <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                <Button text="⊞  Tổng quan"         maxWidth="Infinity" styleClass="nav-btn" onAction="#handleBack"/>
                <Button text="☰  Danh sách phiên"    maxWidth="Infinity" styleClass="nav-btn" onAction="#handleAuctionList"/>
                <Button text="⚡  Đấu giá trực tiếp"  maxWidth="Infinity" styleClass="nav-btn" onAction="#handleLiveAuction"/>
                <Button fx:id="btnSellerProducts"   text="📦  Sản phẩm của tôi" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleSellerProducts" visible="false" managed="false"/>
                <Button fx:id="btnAdminProducts"    text="🛠  Quản lý sản phẩm" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleAdminProducts" visible="false" managed="false"/>
                <Button text="💳  Ví &amp; Giao dịch" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleWallet"/>
                <Button text="★  Đánh giá"           maxWidth="Infinity" styleClass="nav-btn" onAction="#handleRating"/>
                <Button text="?  Trợ giúp"            maxWidth="Infinity" styleClass="nav-btn,nav-active" onAction="#handleHelp"/>
            </VBox>

            <VBox styleClass="sidebar-cats" spacing="2">
                <padding><Insets top="8" right="8" bottom="8" left="16"/></padding>
                <Label text="DANH MỤC" styleClass="cat-title"/>
                <Button text="🖥️  Điện tử"    maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDienTu"/>
                <Button text="📷  Máy ảnh"    maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryMayAnh"/>
                <Button text="💻  Laptop"     maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryLaptop"/>
                <Button text="📱  Điện thoại" maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDienThoai"/>
                <Button text="⌚  Đồng hồ"   maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDongHo"/>
                <Button text="🚗  Xe cộ"     maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryXeCo"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- ══ HEADER ══ -->
    <top>
        <HBox styleClass="header" spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="0" right="20" bottom="0" left="20"/></padding>
            <Button text="← Quay lại" onAction="#handleBack" styleClass="btn-secondary"/>
            <Label text="?  Trợ giúp &amp; FAQ" styleClass="header-username"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🔔" styleClass="icon-btn"/>
            <Separator orientation="VERTICAL"/>
            <MenuButton styleClass="profile-menu-btn">
                <graphic>
                    <HBox spacing="8" alignment="CENTER">
                        <Label fx:id="userAvatarLabel" styleClass="profile-avatar"/>
                        <VBox alignment="CENTER_LEFT">
                            <Label fx:id="userNameLabel" styleClass="header-username"/>
                            <Label fx:id="userRoleLabel" styleClass="header-role"/>
                        </VBox>
                    </HBox>
                </graphic>
                <items>
                    <MenuItem text="👤  Hồ sơ"     onAction="#handleProfile"/>
                    <MenuItem text="📋  Lịch sử"   onAction="#handleHistory"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="🚪  Đăng xuất" onAction="#handleLogout"/>
                </items>
            </MenuButton>
        </HBox>
    </top>

    <!-- ══ CONTENT ══ -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="main-root"
                    style="-fx-border-color: transparent;">
            <VBox spacing="24" style="-fx-background-color: #FFF8F0;">
                <padding><Insets top="28" right="32" bottom="32" left="32"/></padding>

                <!-- Hero -->
                <VBox alignment="CENTER" spacing="8"
                      style="-fx-background-color: #1F0C40;
                             -fx-border-color: #1A1A1A;
                             -fx-border-width: 3px;
                             -fx-padding: 32 0 32 0;
                             -fx-effect: dropshadow(gaussian, #1A1A1A, 6, 0, 0, 0);">
                    <Label text="❓" style="-fx-font-size: 48px;"/>
                    <Label text="Trung tâm Trợ giúp"
                           style="-fx-text-fill: #FFFFFF; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <Label text="Tìm câu trả lời cho các câu hỏi thường gặp"
                           style="-fx-text-fill: #B0A0D0; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Search -->
                <HBox spacing="10" alignment="CENTER">
                    <TextField fx:id="searchHelpField"
                               promptText="🔍  Tìm kiếm câu hỏi..."
                               onAction="#handleSearch"
                               prefWidth="480"
                               styleClass="search-field"/>
                    <Button text="Tìm kiếm" onAction="#handleSearch"
                            styleClass="btn-primary"
                            style="-fx-padding: 10 20 10 20;"/>
                </HBox>

                <!-- Quick links -->
                <HBox spacing="12" alignment="CENTER">
                    <Button text="💳 Nạp tiền"  styleClass="btn-secondary" onAction="#handleWallet"            style="-fx-padding: 8 16 8 16;"/>
                    <Button text="⚡ Đấu giá"   styleClass="btn-secondary" onAction="#handleLiveAuction"       style="-fx-padding: 8 16 8 16;"/>
                    <Button text="📦 Đăng bán"  styleClass="btn-secondary" onAction="#handleProductManagement" style="-fx-padding: 8 16 8 16;"/>
                    <Button text="📋 Lịch sử"   styleClass="btn-secondary" onAction="#handleHistory"           style="-fx-padding: 8 16 8 16;"/>
                </HBox>

                <!-- FAQ title -->
                <HBox alignment="CENTER_LEFT"
                      style="-fx-border-color: transparent transparent #1A1A1A transparent;
                             -fx-border-width: 0 0 3 0;
                             -fx-padding: 0 0 8 0;">
                    <Label text="Câu hỏi thường gặp"
                           style="-fx-text-fill: #1F0C40; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                </HBox>

                <!-- FAQ list (render động) -->
                <VBox fx:id="faqListBox" spacing="10"/>

                <!-- Contact -->
                <VBox alignment="CENTER" spacing="6"
                      style="-fx-background-color: #FFFFFF;
                             -fx-border-color: #1A1A1A;
                             -fx-border-width: 3px;
                             -fx-padding: 24;
                             -fx-effect: dropshadow(gaussian, #1A1A1A, 6, 0, 0, 0);">
                    <Label text="Vẫn cần hỗ trợ?"
                           style="-fx-text-fill: #1F0C40; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label text="Liên hệ đội ngũ hỗ trợ của chúng tôi"
                           style="-fx-text-fill: #666666; -fx-font-size: 13px;"/>
                    <HBox spacing="16" alignment="CENTER">
                        <padding><Insets top="8"/></padding>
                        <Label text="📧 support@auctionsys.vn"
                               style="-fx-text-fill: #FF6B35; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label text="|" style="-fx-text-fill: #1A1A1A; -fx-font-weight: bold;"/>
                        <Label text="📞 1800-1234"
                               style="-fx-text-fill: #FF6B35; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label text="|" style="-fx-text-fill: #1A1A1A; -fx-font-weight: bold;"/>
                        <Label text="⏰ 8:00 – 22:00 mỗi ngày"
                               style="-fx-text-fill: #666666; -fx-font-size: 13px;"/>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
