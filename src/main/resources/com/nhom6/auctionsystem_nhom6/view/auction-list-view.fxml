<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.nhom6.auctionsystem_nhom6.controller.AuctionListController"
            stylesheets="@../styles/main.css"
            styleClass="main-root">

    <!-- ══ SIDEBAR ══ -->
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <HBox styleClass="sidebar-logo" spacing="15" alignment="CENTER_LEFT">
                <padding><Insets top="25" right="16" bottom="25" left="16"/></padding>
                <ImageView fitWidth="55" fitHeight="55" preserveRatio="true" smooth="true">
                    <image><Image url="@../images/logo.png"/></image>
                </ImageView>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="AuctionSys"       styleClass="logo-name"/>
                    <Label text="Hệ thống đấu giá" styleClass="logo-sub"/>
                </VBox>
            </HBox>

            <VBox styleClass="sidebar-nav" spacing="2">
                <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                <Button text="⊞  Tổng quan"         maxWidth="Infinity" styleClass="nav-btn" onAction="#handleBack"/>
                <Button text="☰  Danh sách phiên"    maxWidth="Infinity" styleClass="nav-btn,nav-active" onAction="#handleAuctionList"/>
                <Button text="⚡  Đấu giá trực tiếp"  maxWidth="Infinity" styleClass="nav-btn" onAction="#handleLiveAuction"/>
                <Button fx:id="btnSellerProducts"   text="📦  Sản phẩm của tôi" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleSellerProducts" visible="false" managed="false"/>
                <Button fx:id="btnAdminProducts"    text="🛠  Quản lý sản phẩm" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleAdminProducts" visible="false" managed="false"/>
                <Button text="💳  Ví &amp; Giao dịch" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleWallet"/>
                <Button text="★  Đánh giá"           maxWidth="Infinity" styleClass="nav-btn" onAction="#handleRating"/>
                <Button text="?  Trợ giúp"            maxWidth="Infinity" styleClass="nav-btn" onAction="#handleHelp"/>
            </VBox>

            <VBox styleClass="sidebar-cats" spacing="2">
                <padding><Insets top="8" right="8" bottom="8" left="16"/></padding>
                <Label text="DANH MỤC" styleClass="cat-title"/>
                <Button text="🖥️  Điện tử"    maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDienTu"/>
                <Button text="📷  Máy ảnh"    maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryMayAnh"/>
                <Button text="💻  Laptop"     maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryLaptop"/>
                <Button text="📱  Điện thoại" maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDienThoai"/>
                <Button text="⌚  Đồng hồ"   maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDongHo"/>
                <Button text="🚗  Xe cộ"     maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryXeCo"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <top>
        <HBox styleClass="header" spacing="15" alignment="CENTER_LEFT"
              style="-fx-background-color: #1F0C40; -fx-border-color: #1A1A1A; -fx-border-width: 0 0 4 0;">
            <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
            <Button text="← QUAY LẠI" onAction="#handleBack" styleClass="btn-secondary"
                    style="-fx-background-color: #FFFFFF; -fx-text-fill: #1A1A1A; -fx-font-weight: 900; -fx-border-color: #1A1A1A; -fx-border-width: 3; -fx-background-radius: 0;"/>
            <Label text="DANH SÁCH PHIÊN ĐẤU GIÁ" styleClass="header-username"
                   style="-fx-text-fill: #FFFFFF; -fx-font-weight: 900; -fx-letter-spacing: 2px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="statusFilter" promptText="Trạng thái" onAction="#handleFilter"
                      style="-fx-background-color: #FFFFFF; -fx-border-color: #1A1A1A; -fx-border-width: 3; -fx-background-radius: 0;"/>
            <ComboBox fx:id="categoryFilter" promptText="Danh mục" onAction="#handleFilter"
                      style="-fx-background-color: #FFFFFF; -fx-border-color: #1A1A1A; -fx-border-width: 3; -fx-background-radius: 0;"/>
            <TextField fx:id="searchField" promptText="Tìm phiên..." prefWidth="200" onKeyReleased="#handleSearch"
                       style="-fx-background-color: #FFFFFF; -fx-border-color: #1A1A1A; -fx-border-width: 3; -fx-background-radius: 0;"/>
        </HBox>
    </top>

    <center>
        <VBox styleClass="content-area" spacing="16">
            <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>

            <!-- Stat cards -->
            <HBox spacing="12">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label fx:id="totalLabel"   text="0" styleClass="stat-big-num"/>
                    <Label text="Tổng phiên"    styleClass="stat-big-label"/>
                </VBox>
                <VBox styleClass="stat-card stat-card-success" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label fx:id="runningLabel" text="0" styleClass="stat-big-num"/>
                    <Label text="Đang diễn ra"  styleClass="stat-big-label"/>
                </VBox>
                <VBox styleClass="stat-card stat-card-warn" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label fx:id="upcomingLabel" text="0" styleClass="stat-big-num"/>
                    <Label text="Sắp diễn ra"   styleClass="stat-big-label"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label fx:id="endedLabel"   text="0" styleClass="stat-big-num"/>
                    <Label text="Đã kết thúc"   styleClass="stat-big-label"/>
                </VBox>
            </HBox>

            <!-- Tab bar -->
            <HBox styleClass="tab-bar" spacing="0">
                <Button fx:id="tabAllBtn"     text="📋  Tất cả"
                        styleClass="tab-btn,tab-active"
                        onAction="#handleTabAll" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                <Button fx:id="tabRunBtn"     text="🟢  Đang diễn ra"
                        styleClass="tab-btn"
                        onAction="#handleTabRunning" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                <Button fx:id="tabUpBtn"      text="⏰  Sắp diễn ra"
                        styleClass="tab-btn"
                        onAction="#handleTabUpcoming" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                <Button fx:id="tabEndBtn"     text="🏁  Đã kết thúc"
                        styleClass="tab-btn"
                        onAction="#handleTabEnded" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Danh sách phiên -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="bid-scroll">
                <VBox fx:id="sessionListBox" spacing="10">
                    <padding><Insets top="4" right="0" bottom="8" left="0"/></padding>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
