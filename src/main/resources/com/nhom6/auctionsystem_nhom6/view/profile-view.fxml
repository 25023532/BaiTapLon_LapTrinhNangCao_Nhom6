<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.nhom6.auctionsystem_nhom6.controller.ProfileController"
            stylesheets="@../styles/main.css"
            styleClass="main-root">

    <!-- ══ SIDEBAR ══ -->
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <HBox styleClass="sidebar-logo" spacing="15" alignment="CENTER_LEFT">
                <padding><Insets top="25" right="16" bottom="25" left="16"/></padding>
                <ImageView fitWidth="55" fitHeight="55" preserveRatio="true" smooth="true">
                    <image><Image url="@../images/logo.png"/></image>
                </ImageView>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="AuctionSys"       styleClass="logo-name"/>
                    <Label text="Hệ thống đấu giá" styleClass="logo-sub"/>
                </VBox>
            </HBox>

            <VBox styleClass="sidebar-nav" spacing="2">
                <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                <Button text="⊞  Tổng quan"         maxWidth="Infinity" styleClass="nav-btn" onAction="#handleBack"/>
                <Button text="☰  Danh sách phiên"    maxWidth="Infinity" styleClass="nav-btn" onAction="#handleAuctionList"/>
                <Button text="⚡  Đấu giá trực tiếp"  maxWidth="Infinity" styleClass="nav-btn" onAction="#handleLiveAuction"/>
                <Button fx:id="btnSellerProducts"   text="📦  Sản phẩm của tôi" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleSellerProducts" visible="false" managed="false"/>
                <Button fx:id="btnAdminProducts"    text="🛠  Quản lý sản phẩm" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleAdminProducts" visible="false" managed="false"/>
                <Button text="💳  Ví &amp; Giao dịch" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleWallet"/>
                <Button text="★  Đánh giá"           maxWidth="Infinity" styleClass="nav-btn" onAction="#handleRating"/>
                <Button text="?  Trợ giúp"            maxWidth="Infinity" styleClass="nav-btn" onAction="#handleHelp"/>
            </VBox>

            <VBox styleClass="sidebar-cats" spacing="2">
                <padding><Insets top="8" right="8" bottom="8" left="16"/></padding>
                <Label text="DANH MỤC" styleClass="cat-title"/>
                <Button text="🖥️  Điện tử"    maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDienTu"/>
                <Button text="📷  Máy ảnh"    maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryMayAnh"/>
                <Button text="💻  Laptop"     maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryLaptop"/>
                <Button text="📱  Điện thoại" maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDienThoai"/>
                <Button text="⌚  Đồng hồ"   maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDongHo"/>
                <Button text="🚗  Xe cộ"     maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryXeCo"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- ══ HEADER ══ -->
    <top>
        <HBox styleClass="header" spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="0" right="20" bottom="0" left="20"/></padding>
            <Button text="← Quay lại" onAction="#handleBack" styleClass="btn-secondary"/>
            <Label text="Hồ sơ cá nhân" styleClass="header-username"/>
        </HBox>
    </top>

    <!-- ══ CONTENT ══ -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="profile-scroll">
            <VBox alignment="TOP_CENTER" spacing="24">
                <padding><Insets top="32" right="0" bottom="32" left="0"/></padding>

                <!-- Profile Card -->
                <VBox styleClass="profile-card" maxWidth="480" spacing="20">
                    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

                    <!-- Avatar + tên -->
                    <HBox alignment="CENTER" spacing="16">
                        <Label fx:id="avatarLabel" styleClass="profile-avatar-large"/>
                        <VBox spacing="4" alignment="CENTER_LEFT">
                            <Label fx:id="displayNameLabel" styleClass="login-title"/>
                            <Label fx:id="roleLabel"        styleClass="login-subtitle"/>
                        </VBox>
                    </HBox>

                    <Separator/>

                    <!-- Tên đăng nhập (readonly) -->
                    <VBox spacing="6">
                        <Label text="* Tên đăng nhập" styleClass="form-label"/>
                        <TextField fx:id="usernameField"
                                   promptText="Tối thiểu 4 ký tự..."
                                   styleClass="login-input"
                                   editable="false"/>
                    </VBox>

                    <!-- Họ và tên -->
                    <VBox spacing="6">
                        <Label text="Họ và tên" styleClass="form-label"/>
                        <TextField fx:id="fullNameField"
                                   promptText="Nguyễn Văn A..."
                                   styleClass="login-input"/>
                    </VBox>

                    <!-- Email -->
                    <VBox spacing="6">
                        <Label text="Email" styleClass="form-label"/>
                        <TextField fx:id="emailField"
                                   promptText="example@email.com"
                                   styleClass="login-input"/>
                    </VBox>

                    <Separator/>

                    <!-- Đổi mật khẩu -->
                    <VBox spacing="6">
                        <Label text="* Đổi mật khẩu" styleClass="form-label"/>
                        <PasswordField fx:id="newPasswordField"
                                       promptText="Tối thiểu 6 ký tự..."
                                       styleClass="login-input"/>
                    </VBox>

                    <!-- Xác nhận mật khẩu -->
                    <VBox spacing="6">
                        <Label text="* Xác nhận mật khẩu" styleClass="form-label"/>
                        <PasswordField fx:id="confirmPasswordField"
                                       promptText="Nhập lại mật khẩu..."
                                       styleClass="login-input"/>
                    </VBox>

                    <!-- Thông báo -->
                    <Label fx:id="messageLabel" styleClass="login-error"
                           wrapText="true" visible="false"/>

                    <!-- Nút lưu -->
                    <Button text="💾  Lưu thay đổi" onAction="#handleSave"
                            maxWidth="Infinity" styleClass="btn-primary"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
