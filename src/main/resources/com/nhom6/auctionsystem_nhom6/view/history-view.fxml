<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.nhom6.auctionsystem_nhom6.controller.HistoryController"
            stylesheets="@../styles/main.css"
            styleClass="main-root">

    <!-- ══ SIDEBAR ══ -->
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <HBox styleClass="sidebar-logo" spacing="15" alignment="CENTER_LEFT">
                <padding><Insets top="25" right="16" bottom="25" left="16"/></padding>
                <ImageView fitWidth="55" fitHeight="55" preserveRatio="true" smooth="true">
                    <image><Image url="@../images/logo.png"/></image>
                </ImageView>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="AuctionSys"       styleClass="logo-name"/>
                    <Label text="Hệ thống đấu giá" styleClass="logo-sub"/>
                </VBox>
            </HBox>

            <VBox styleClass="sidebar-nav" spacing="2">
                <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                <Button text="⊞  Tổng quan"         maxWidth="Infinity" styleClass="nav-btn" onAction="#handleBack"/>
                <Button text="☰  Danh sách phiên"    maxWidth="Infinity" styleClass="nav-btn" onAction="#handleAuctionList"/>
                <Button text="⚡  Đấu giá trực tiếp"  maxWidth="Infinity" styleClass="nav-btn" onAction="#handleLiveAuction"/>
                <Button fx:id="btnSellerProducts"   text="📦  Sản phẩm của tôi" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleSellerProducts" visible="false" managed="false"/>
                <Button fx:id="btnAdminProducts"    text="🛠  Quản lý sản phẩm" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleAdminProducts" visible="false" managed="false"/>
                <Button text="💳  Ví &amp; Giao dịch" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleWallet"/>
                <Button text="★  Đánh giá"           maxWidth="Infinity" styleClass="nav-btn" onAction="#handleRating"/>
                <Button text="?  Trợ giúp"            maxWidth="Infinity" styleClass="nav-btn" onAction="#handleHelp"/>
            </VBox>

            <VBox styleClass="sidebar-cats" spacing="2">
                <padding><Insets top="8" right="8" bottom="8" left="16"/></padding>
                <Label text="DANH MỤC" styleClass="cat-title"/>
                <Button text="🖥️  Điện tử"    maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDienTu"/>
                <Button text="📷  Máy ảnh"    maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryMayAnh"/>
                <Button text="💻  Laptop"     maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryLaptop"/>
                <Button text="📱  Điện thoại" maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDienThoai"/>
                <Button text="⌚  Đồng hồ"   maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDongHo"/>
                <Button text="🚗  Xe cộ"     maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryXeCo"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- ══ HEADER ══ -->
    <top>
        <HBox styleClass="header" spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="0" right="20" bottom="0" left="20"/></padding>
            <Button text="← Quay lại" onAction="#handleBack" styleClass="btn-secondary"/>
            <Label fx:id="pageTitleLabel" styleClass="header-username"/>
            <Region HBox.hgrow="ALWAYS"/>
            <!-- Bộ lọc trạng thái -->
            <ComboBox fx:id="statusFilter" promptText="Tất cả trạng thái"
                      styleClass="filter-combo" onAction="#handleFilter"/>
            <!-- Tìm kiếm -->
            <TextField fx:id="searchField" promptText="Tìm kiếm..."
                       prefWidth="200" styleClass="search-field"
                       onKeyReleased="#handleSearch"/>
        </HBox>
    </top>

    <!-- ══ CONTENT ══ -->
    <center>
        <VBox styleClass="content-area" spacing="16">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <!-- Thống kê tổng quan -->
            <HBox spacing="16">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label fx:id="totalCountLabel"  text="0" styleClass="stat-big-num"/>
                    <Label fx:id="totalCountDesc"   text="Tổng đơn" styleClass="stat-big-label"/>
                </VBox>
                <VBox styleClass="stat-card stat-card-success" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label fx:id="successCountLabel" text="0" styleClass="stat-big-num"/>
                    <Label fx:id="successCountDesc"  text="Thành công" styleClass="stat-big-label"/>
                </VBox>
                <VBox styleClass="stat-card stat-card-warn" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label fx:id="pendingCountLabel" text="0" styleClass="stat-big-num"/>
                    <Label fx:id="pendingCountDesc"  text="Chờ xử lý" styleClass="stat-big-label"/>
                </VBox>
                <VBox styleClass="stat-card stat-card-info" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label fx:id="totalValueLabel" text="₫ 0" styleClass="stat-big-num"/>
                    <Label fx:id="totalValueDesc"  text="Tổng giá trị" styleClass="stat-big-label"/>
                </VBox>
            </HBox>

            <!-- Tab Bidder: Lịch sử đặt giá + Đơn thắng | Tab Seller: Bán + Đơn chờ -->
            <HBox styleClass="tab-bar" spacing="0">
                <Button fx:id="tab1Btn" text="📋  Tất cả" styleClass="tab-btn,tab-active"
                        onAction="#handleTab1" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                <Button fx:id="tab2Btn" styleClass="tab-btn"
                        onAction="#handleTab2" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Danh sách đơn -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="bid-scroll">
                <VBox fx:id="historyListBox" spacing="10">
                    <padding><Insets top="8" right="0" bottom="8" left="0"/></padding>
                </VBox>
            </ScrollPane>

        </VBox>
    </center>
</BorderPane>
