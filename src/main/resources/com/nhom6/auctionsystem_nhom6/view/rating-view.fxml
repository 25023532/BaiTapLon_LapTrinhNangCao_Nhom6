<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.nhom6.auctionsystem_nhom6.controller.RatingController"
            styleClass="main-root">

    <!-- ══ SIDEBAR ══ -->
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <HBox styleClass="sidebar-logo" spacing="15" alignment="CENTER_LEFT">
                <padding><Insets top="25" right="16" bottom="25" left="16"/></padding>
                <ImageView fitWidth="55" fitHeight="55" preserveRatio="true" smooth="true">
                    <image><Image url="@../images/logo.png"/></image>
                </ImageView>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="AuctionSys"       styleClass="logo-name"/>
                    <Label text="Hệ thống đấu giá" styleClass="logo-sub"/>
                </VBox>
            </HBox>

            <VBox styleClass="sidebar-nav" spacing="2">
                <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                <Button text="⊞  Tổng quan"         maxWidth="Infinity" styleClass="nav-btn" onAction="#handleBack"/>
                <Button text="☰  Danh sách phiên"    maxWidth="Infinity" styleClass="nav-btn" onAction="#handleAuctionList"/>
                <Button text="⚡  Đấu giá trực tiếp"  maxWidth="Infinity" styleClass="nav-btn" onAction="#handleLiveAuction"/>
                <Button fx:id="btnSellerProducts"   text="📦  Sản phẩm của tôi" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleSellerProducts" visible="false" managed="false"/>
                <Button fx:id="btnAdminProducts"    text="🛠  Quản lý sản phẩm" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleAdminProducts" visible="false" managed="false"/>
                <Button text="💳  Ví &amp; Giao dịch" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleWallet"/>
                <Button text="★  Đánh giá"           maxWidth="Infinity" styleClass="nav-btn,nav-active" onAction="#handleRating"/>
                <Button text="?  Trợ giúp"            maxWidth="Infinity" styleClass="nav-btn" onAction="#handleHelp"/>
            </VBox>

            <VBox styleClass="sidebar-cats" spacing="2">
                <padding><Insets top="8" right="8" bottom="8" left="16"/></padding>
                <Label text="DANH MỤC" styleClass="cat-title"/>
                <Button text="🖥️  Điện tử"    maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDienTu"/>
                <Button text="📷  Máy ảnh"    maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryMayAnh"/>
                <Button text="💻  Laptop"     maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryLaptop"/>
                <Button text="📱  Điện thoại" maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDienThoai"/>
                <Button text="⌚  Đồng hồ"   maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDongHo"/>
                <Button text="🚗  Xe cộ"     maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryXeCo"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- ══ HEADER ══ -->
    <top>
        <HBox styleClass="header" spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="0" right="20" bottom="0" left="20"/></padding>
            <Button text="← Quay lại" onAction="#handleBack" styleClass="btn-secondary"/>
            <Label text="★  Đánh giá &amp; Nhận xét" styleClass="header-username"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🔔" styleClass="icon-btn"/>
            <Separator orientation="VERTICAL"/>
            <MenuButton styleClass="profile-menu-btn">
                <graphic>
                    <HBox spacing="8" alignment="CENTER">
                        <Label fx:id="userAvatarLabel" styleClass="profile-avatar"/>
                        <VBox alignment="CENTER_LEFT">
                            <Label fx:id="userNameLabel" styleClass="header-username"/>
                            <Label fx:id="userRoleLabel" styleClass="header-role"/>
                        </VBox>
                    </HBox>
                </graphic>
                <items>
                    <MenuItem text="👤  Hồ sơ"     onAction="#handleProfile"/>
                    <MenuItem text="📋  Lịch sử"   onAction="#handleHistory"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="🚪  Đăng xuất" onAction="#handleLogout"/>
                </items>
            </MenuButton>
        </HBox>
    </top>

    <!-- ══ CONTENT ══ -->
    <center>
        <HBox spacing="16" fillHeight="true" style="-fx-background-color: #FFF8F0;">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <!-- ══ CỘT TRÁI: Stats + Write Review ══ -->
            <VBox spacing="12" minWidth="340" maxWidth="340">

                <!-- TỔNG QUAN ĐÁNH GIÁ -->
                <VBox spacing="12"
                      style="-fx-background-color: #FFFFFF;
                             -fx-border-color: #1A1A1A;
                             -fx-border-width: 3px;
                             -fx-effect: dropshadow(gaussian, #1A1A1A, 6, 0, 0, 0);
                             -fx-padding: 20;">

                    <Label text="📊  Tổng quan đánh giá"
                           style="-fx-text-fill: #1F0C40; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <Separator style="-fx-background-color: #1A1A1A; -fx-border-color: #1A1A1A;"/>

                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <VBox alignment="CENTER" minWidth="80" spacing="2">
                            <Label fx:id="avgRatingLabel" text="—"
                                   style="-fx-text-fill: #FF6B35; -fx-font-size: 48px; -fx-font-weight: bold;"/>
                            <Label fx:id="avgStarsLabel" text="☆☆☆☆☆"
                                   style="-fx-text-fill: #FF6B35; -fx-font-size: 14px;"/>
                            <Label fx:id="totalReviewsLabel" text="0 đánh giá"
                                   style="-fx-text-fill: #666666; -fx-font-size: 12px;"/>
                        </VBox>

                        <!-- Thanh phân bổ sao -->
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="10★" style="-fx-text-fill: #1F0C40; -fx-font-size: 11px; -fx-font-weight: bold;" minWidth="28"/>
                                <ProgressBar fx:id="bar10" progress="0" prefHeight="8" HBox.hgrow="ALWAYS" style="-fx-accent: #FF6B35;"/>
                                <Label fx:id="count10Label" text="0" style="-fx-text-fill: #666666; -fx-font-size: 11px;" minWidth="20"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="9★"  style="-fx-text-fill: #1F0C40; -fx-font-size: 11px; -fx-font-weight: bold;" minWidth="28"/>
                                <ProgressBar fx:id="bar9"  progress="0" prefHeight="8" HBox.hgrow="ALWAYS" style="-fx-accent: #FF6B35;"/>
                                <Label fx:id="count9Label"  text="0" style="-fx-text-fill: #666666; -fx-font-size: 11px;" minWidth="20"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="8★"  style="-fx-text-fill: #1F0C40; -fx-font-size: 11px; -fx-font-weight: bold;" minWidth="28"/>
                                <ProgressBar fx:id="bar8"  progress="0" prefHeight="8" HBox.hgrow="ALWAYS" style="-fx-accent: #FF6B35;"/>
                                <Label fx:id="count8Label"  text="0" style="-fx-text-fill: #666666; -fx-font-size: 11px;" minWidth="20"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="7★"  style="-fx-text-fill: #1F0C40; -fx-font-size: 11px; -fx-font-weight: bold;" minWidth="28"/>
                                <ProgressBar fx:id="bar7"  progress="0" prefHeight="8" HBox.hgrow="ALWAYS" style="-fx-accent: #FF6B35;"/>
                                <Label fx:id="count7Label"  text="0" style="-fx-text-fill: #666666; -fx-font-size: 11px;" minWidth="20"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="6★"  style="-fx-text-fill: #1F0C40; -fx-font-size: 11px; -fx-font-weight: bold;" minWidth="28"/>
                                <ProgressBar fx:id="bar6"  progress="0" prefHeight="8" HBox.hgrow="ALWAYS" style="-fx-accent: #FF6B35;"/>
                                <Label fx:id="count6Label"  text="0" style="-fx-text-fill: #666666; -fx-font-size: 11px;" minWidth="20"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="5★"  style="-fx-text-fill: #1F0C40; -fx-font-size: 11px; -fx-font-weight: bold;" minWidth="28"/>
                                <ProgressBar fx:id="bar5"  progress="0" prefHeight="8" HBox.hgrow="ALWAYS" style="-fx-accent: #1F0C40;"/>
                                <Label fx:id="count5Label"  text="0" style="-fx-text-fill: #666666; -fx-font-size: 11px;" minWidth="20"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="4★"  style="-fx-text-fill: #1F0C40; -fx-font-size: 11px; -fx-font-weight: bold;" minWidth="28"/>
                                <ProgressBar fx:id="bar4"  progress="0" prefHeight="8" HBox.hgrow="ALWAYS" style="-fx-accent: #1F0C40;"/>
                                <Label fx:id="count4Label"  text="0" style="-fx-text-fill: #666666; -fx-font-size: 11px;" minWidth="20"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="3★"  style="-fx-text-fill: #1F0C40; -fx-font-size: 11px; -fx-font-weight: bold;" minWidth="28"/>
                                <ProgressBar fx:id="bar3"  progress="0" prefHeight="8" HBox.hgrow="ALWAYS" style="-fx-accent: #1F0C40;"/>
                                <Label fx:id="count3Label"  text="0" style="-fx-text-fill: #666666; -fx-font-size: 11px;" minWidth="20"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="2★"  style="-fx-text-fill: #1F0C40; -fx-font-size: 11px; -fx-font-weight: bold;" minWidth="28"/>
                                <ProgressBar fx:id="bar2"  progress="0" prefHeight="8" HBox.hgrow="ALWAYS" style="-fx-accent: #1F0C40;"/>
                                <Label fx:id="count2Label"  text="0" style="-fx-text-fill: #666666; -fx-font-size: 11px;" minWidth="20"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="1★"  style="-fx-text-fill: #1F0C40; -fx-font-size: 11px; -fx-font-weight: bold;" minWidth="28"/>
                                <ProgressBar fx:id="bar1"  progress="0" prefHeight="8" HBox.hgrow="ALWAYS" style="-fx-accent: #1F0C40;"/>
                                <Label fx:id="count1Label"  text="0" style="-fx-text-fill: #666666; -fx-font-size: 11px;" minWidth="20"/>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- VIẾT ĐÁNH GIÁ -->
                <VBox spacing="12" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #FFFFFF;
                             -fx-border-color: #1A1A1A;
                             -fx-border-width: 3px;
                             -fx-effect: dropshadow(gaussian, #1A1A1A, 6, 0, 0, 0);
                             -fx-padding: 20;">

                    <Label text="✏️  Viết đánh giá"
                           style="-fx-text-fill: #1F0C40; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <Separator style="-fx-background-color: #1A1A1A;"/>

                    <Label text="Chọn số sao (1-10):"
                           style="-fx-text-fill: #666666; -fx-font-size: 12px;"/>
                    <HBox fx:id="starRow" spacing="4" alignment="CENTER_LEFT"/>
                    <Label fx:id="selectedStarLabel" text="Chưa chọn sao"
                           style="-fx-text-fill: #999999; -fx-font-size: 12px;"/>

                    <Label text="Nhận xét của bạn:"
                           style="-fx-text-fill: #666666; -fx-font-size: 12px;"/>
                    <TextArea fx:id="commentArea"
                              promptText="Chia sẻ trải nghiệm của bạn về hệ thống..."
                              prefRowCount="4" wrapText="true"
                              style="-fx-background-color: #FFF8F0;
                                     -fx-text-fill: #1A1A1A;
                                     -fx-prompt-text-fill: #999999;
                                     -fx-border-color: #1A1A1A;
                                     -fx-border-width: 2px;
                                     -fx-border-radius: 0;
                                     -fx-background-radius: 0;
                                     -fx-font-size: 13px;
                                     -fx-padding: 10;"/>

                    <HBox alignment="CENTER_RIGHT">
                        <Label fx:id="charCountLabel" text="0/500"
                               style="-fx-text-fill: #999999; -fx-font-size: 11px;"/>
                    </HBox>

                    <Label fx:id="writeResultLabel" text="" wrapText="true" visible="false"/>

                    <Button text="⭐  Gửi đánh giá" onAction="#handleSubmitReview"
                            maxWidth="Infinity" styleClass="btn-primary"/>
                </VBox>
            </VBox>

            <!-- ══ CỘT PHẢI: Danh sách đánh giá ══ -->
            <VBox spacing="12" HBox.hgrow="ALWAYS">

                <!-- Filter bar -->
                <HBox spacing="10" alignment="CENTER_LEFT"
                      style="-fx-background-color: #FFFFFF;
                             -fx-border-color: #1A1A1A;
                             -fx-border-width: 3px;
                             -fx-padding: 12 16 12 16;
                             -fx-effect: dropshadow(gaussian, #1A1A1A, 4, 0, 0, 0);">

                    <Label text="🔍" style="-fx-font-size: 14px;"/>
                    <TextField fx:id="searchField"
                               promptText="Tìm trong nhận xét..."
                               HBox.hgrow="ALWAYS"
                               styleClass="search-field"
                               onKeyReleased="#handleSearch"/>

                    <Label text="Lọc:" style="-fx-text-fill: #666666; -fx-font-size: 12px;"/>
                    <ComboBox fx:id="filterStarBox" prefWidth="150" onAction="#handleFilter"
                              styleClass="form-field"/>

                    <Label text="Sắp xếp:" style="-fx-text-fill: #666666; -fx-font-size: 12px;"/>
                    <ComboBox fx:id="sortBox" prefWidth="160" onAction="#handleFilter"
                              styleClass="form-field"/>
                </HBox>

                <!-- Count -->
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="reviewCountLabel" text="0 đánh giá" styleClass="product-desc"/>
                </HBox>

                <!-- List -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background: #FFF8F0;
                                   -fx-background-color: #FFF8F0;
                                   -fx-border-width: 0;">
                    <VBox fx:id="reviewListBox" spacing="10">
                        <padding><Insets top="0" right="4" bottom="0" left="0"/></padding>
                    </VBox>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>

</BorderPane>
