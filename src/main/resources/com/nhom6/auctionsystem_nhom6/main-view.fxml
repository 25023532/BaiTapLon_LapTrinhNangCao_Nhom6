<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.nhom6.auctionsystem_nhom6.MainController"
            styleClass="main-root">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>

        <VBox spacing="0" styleClass="sidebar">

            <!-- Logo -->
            <HBox spacing="10"
                   alignment="CENTER_LEFT"
                   styleClass="sidebar-logo">

                <padding>
                    <Insets top="20" right="16" bottom="20" left="16"/>
                </padding>

                <Label text="⬡" styleClass="logo-icon"/>

                <VBox>
                    <Label text="AuctionSys" styleClass="logo-name"/>
                    <Label text="Hệ thống đấu giá" styleClass="logo-sub"/>
                </VBox>
            </HBox>

            <!-- Navigation -->
            <VBox spacing="4">

                <padding>
                    <Insets top="10" right="8" bottom="10" left="8"/>
                </padding>

                <Button text="⊞ Tổng quan"
                        maxWidth="Infinity"
                        styleClass="nav-btn nav-active"/>

                <Button text="☰ Danh sách phiên"
                        maxWidth="Infinity"
                        styleClass="nav-btn"/>

                <Button text="⚡ Đấu giá trực tiếp"
                        maxWidth="Infinity"
                        styleClass="nav-btn"/>

                <Button text="📦 Quản lý sản phẩm"
                        maxWidth="Infinity"
                        styleClass="nav-btn"/>

                <Button text="🛒 Đơn hàng của tôi"
                        maxWidth="Infinity"
                        styleClass="nav-btn"/>

                <Button text="💳 Ví &amp; Giao dịch"
                        maxWidth="Infinity"
                        styleClass="nav-btn"/>
            </VBox>

            <!-- Categories -->
            <VBox spacing="4">

                <padding>
                    <Insets top="8" right="8" bottom="8" left="16"/>
                </padding>

                <Label text="DANH MỤC"
                       styleClass="cat-title"/>

                <Button text="🖥️ Điện tử"
                        maxWidth="Infinity"
                        styleClass="cat-btn"/>

                <Button text="📱 Điện thoại"
                        maxWidth="Infinity"
                        styleClass="cat-btn"/>

                <Button text="💻 Laptop"
                        maxWidth="Infinity"
                        styleClass="cat-btn"/>

                <Button text="⌚ Đồng hồ"
                        maxWidth="Infinity"
                        styleClass="cat-btn"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

        </VBox>

    </left>

    <!-- ================= HEADER ================= -->
    <top>

        <HBox spacing="12"
               alignment="CENTER_LEFT"
               styleClass="header">

            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <!-- Search -->
            <TextField fx:id="searchField"
                       promptText="Tìm kiếm sản phẩm..."
                       HBox.hgrow="ALWAYS"
                       styleClass="search-field"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Notification -->
            <Button text="🔔"
                    styleClass="icon-btn"/>

            <Separator orientation="VERTICAL"/>

            <!-- Wallet -->
            <VBox alignment="CENTER_RIGHT">

                <Label text="Số dư"
                       styleClass="wallet-label"/>

                <Label fx:id="walletLabel"
                       text="0 VNĐ"
                       styleClass="wallet-amount"/>
            </VBox>

            <Separator orientation="VERTICAL"/>

            <!-- Profile -->
            <MenuButton fx:id="profileMenuBtn"
                        styleClass="profile-menu-btn">

                <graphic>

                    <HBox spacing="8"
                           alignment="CENTER">

                        <Label fx:id="userAvatarLabel"
                               text="A"
                               styleClass="profile-avatar"/>

                        <VBox alignment="CENTER_LEFT">

                            <Label fx:id="userNameLabel"
                                   text="Admin"
                                   styleClass="header-username"/>

                            <Label fx:id="userRoleLabel"
                                   text="Administrator"
                                   styleClass="header-role"/>
                        </VBox>
                    </HBox>

                </graphic>

                <items>

                    <MenuItem text="👤 Hồ sơ"
                              onAction="#handleProfile"/>

                    <MenuItem text="📋 Lịch sử"
                              onAction="#handleHistory"/>

                    <MenuItem text="🛒 Đơn hàng"
                              onAction="#handleOrders"/>

                    <SeparatorMenuItem/>

                    <MenuItem text="🚪 Đăng xuất"
                              onAction="#handleLogout"/>

                </items>

            </MenuButton>

        </HBox>

    </top>

    <!-- ================= CENTER ================= -->
    <center>

        <StackPane>

            <VBox spacing="16"
                   style="-fx-background-color: #0f172a;">

                <padding>
                    <Insets top="16" right="16" bottom="16" left="16"/>
                </padding>

                <!-- Auction Card -->
                <HBox spacing="24"
                       styleClass="auction-card">

                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <!-- Product Image -->
                    <VBox alignment="CENTER"
                           minWidth="220"
                           styleClass="product-image-box">

                        <Label text="⬡"
                               styleClass="product-image-icon"/>

                        <Label fx:id="statusLabel"
                               text="RUNNING"
                               styleClass="status-badge"/>
                    </VBox>

                    <!-- Product Info -->
                    <VBox spacing="12"
                           HBox.hgrow="ALWAYS">

                        <Label fx:id="productTitleLabel"
                               text="Phiên đấu giá"
                               styleClass="product-title"/>

                        <Label fx:id="productDescLabel"
                               text="Chưa có sản phẩm."
                               wrapText="true"
                               styleClass="product-desc"/>

                        <!-- Prices -->
                        <HBox spacing="24">

                            <VBox>
                                <Label text="Giá khởi điểm"
                                       styleClass="price-label"/>

                                <Label fx:id="startPriceLabel"
                                       text="0 VNĐ"
                                       styleClass="price-value"/>
                            </VBox>

                            <VBox>
                                <Label text="Giá hiện tại"
                                       styleClass="price-label"/>

                                <Label fx:id="currentPriceLabel"
                                       text="0 VNĐ"
                                       styleClass="price-current-value"/>
                            </VBox>

                            <VBox>
                                <Label text="Bước giá"
                                       styleClass="price-label"/>

                                <Label fx:id="minStepLabel"
                                       text="0 VNĐ"
                                       styleClass="price-value"/>
                            </VBox>
                        </HBox>

                        <!-- Countdown -->
                        <HBox spacing="10"
                               alignment="CENTER_LEFT">

                            <Label fx:id="hoursLabel"
                                   text="00"
                                   styleClass="countdown-num"/>

                            <Label text=":"
                                   styleClass="countdown-sep"/>

                            <Label fx:id="minsLabel"
                                   text="00"
                                   styleClass="countdown-num"/>

                            <Label text=":"
                                   styleClass="countdown-sep"/>

                            <Label fx:id="secsLabel"
                                   text="00"
                                   styleClass="countdown-num"/>
                        </HBox>

                        <!-- Bid Button -->
                        <Button text="ĐẶT GIÁ NGAY!"
                                onAction="#handlePlaceBid"
                                styleClass="btn-bid"/>

                    </VBox>

                </HBox>

                <!-- Bid History -->
                <VBox spacing="8"
                       styleClass="info-card">

                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>

                    <Label text="Lịch sử bid"
                           styleClass="card-title"/>

                    <Separator/>

                    <ScrollPane fitToWidth="true"
                                prefHeight="220"
                                styleClass="bid-scroll">

                        <VBox fx:id="bidHistoryBox"
                               spacing="6">
                        </VBox>

                    </ScrollPane>

                </VBox>

            </VBox>

            <!-- Floating Chat Button -->
            <Button text="💬"
                    styleClass="btn-chat-fab"
                    onAction="#handleToggleChat"
                    StackPane.alignment="BOTTOM_RIGHT">

                <StackPane.margin>
                    <Insets bottom="24" right="24"/>
                </StackPane.margin>

            </Button>

        </StackPane>

    </center>

</BorderPane>
