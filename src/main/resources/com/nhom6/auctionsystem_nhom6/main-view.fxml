<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.SeparatorMenuItem?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.nhom6.auctionsystem_nhom6.MainController"
            styleClass="main-root">

    <!-- ══ SIDEBAR ══ -->
    <left>
        <VBox styleClass="sidebar" spacing="0">

            <HBox styleClass="sidebar-logo" spacing="10" alignment="CENTER_LEFT">
                <padding><Insets top="20" right="16" bottom="20" left="16"/></padding>
                <Label text="⬡" styleClass="logo-icon"/>
                <VBox>
                    <Label text="AuctionSys"       styleClass="logo-name"/>
                    <Label text="Hệ thống đấu giá" styleClass="logo-sub"/>
                </VBox>
            </HBox>

            <VBox styleClass="sidebar-nav" spacing="2">
                <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>

                <!-- Tổng quan: không cần navigate -->
                <Button text="⊞  Tổng quan"
                        maxWidth="Infinity" styleClass="nav-btn,nav-active"/>

                <!-- ✅ Danh sách phiên -->
                <Button text="☰  Danh sách phiên"
                        maxWidth="Infinity" styleClass="nav-btn"
                        onAction="#handleAuctionList"/>

                <!-- ✅ Đấu giá trực tiếp -->
                <Button text="⚡  Đấu giá trực tiếp"
                        maxWidth="Infinity" styleClass="nav-btn"
                        onAction="#handleLiveAuction"/>

                <!-- ✅ Quản lý sản phẩm -->
                <Button text="📦  Quản lý sản phẩm"
                        maxWidth="Infinity" styleClass="nav-btn"
                        onAction="#handleProductManagement"/>

                <Button text="🛒  Đơn hàng của tôi"
                        maxWidth="Infinity" styleClass="nav-btn"/>

                <!-- Ví & Giao dịch -->
                <Button text="💳  Ví &amp; Giao dịch"
                        maxWidth="Infinity" styleClass="nav-btn"
                        onAction="#handleWallet"/>

                <Button text="★  Đánh giá"
                        maxWidth="Infinity" styleClass="nav-btn"/>
                <Button text="?  Trợ giúp"
                        maxWidth="Infinity" styleClass="nav-btn"/>
            </VBox>

            <VBox styleClass="sidebar-cats" spacing="2">
                <padding><Insets top="8" right="8" bottom="8" left="16"/></padding>
                <Label text="DANH MỤC" styleClass="cat-title"/>
                <Button text="🖥️  Điện tử"    maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDienTu"/>
                <Button text="📷  Máy ảnh"    maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryMayAnh"/>
                <Button text="💻  Laptop"     maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryLaptop"/>
                <Button text="📱  Điện thoại" maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDienThoai"/>
                <Button text="⌚  Đồng hồ"   maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryDongHo"/>
                <Button text="🚗  Xe cộ"     maxWidth="Infinity" styleClass="cat-btn" onAction="#handleCategoryXeCo"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- ══ HEADER ══ -->
    <top>
        <HBox styleClass="header" spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="0" right="20" bottom="0" left="20"/></padding>

            <TextField fx:id="searchField"
                       promptText="Tìm kiếm sản phẩm, người bán..."
                       HBox.hgrow="ALWAYS" styleClass="search-field"/>

            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER" spacing="0">
                <StackPane>
                    <Button fx:id="bellButton" text="🔔" styleClass="icon-btn" onAction="#handleBellClick"/>
                    <Label fx:id="badgeLabel" text="0"
                           visible="false" managed="false"
                           style="-fx-background-color:#ef4444;
                      -fx-text-fill:white;
                      -fx-font-size:9px;
                      -fx-font-weight:bold;
                      -fx-background-radius:10;
                      -fx-padding:1 4 1 4;
                      -fx-min-width:16;
                      -fx-alignment:center;"
                           StackPane.alignment="TOP_RIGHT"/>
                </StackPane>
            </VBox>
            <Separator orientation="VERTICAL"/>

            <VBox alignment="CENTER_RIGHT">
                <Label text="Số dư (VNĐ)" styleClass="wallet-label"/>
                <Label fx:id="walletLabel" styleClass="wallet-amount"/>
            </VBox>
            <Separator orientation="VERTICAL"/>

            <MenuButton fx:id="profileMenuBtn" styleClass="profile-menu-btn">
                <graphic>
                    <HBox spacing="8" alignment="CENTER">
                        <Label fx:id="userAvatarLabel" styleClass="profile-avatar"/>
                        <VBox alignment="CENTER_LEFT">
                            <Label fx:id="userNameLabel" styleClass="header-username"/>
                            <Label fx:id="userRoleLabel" styleClass="header-role"/>
                        </VBox>
                    </HBox>
                </graphic>
                <items>
                    <MenuItem text="👤  Hồ sơ"     onAction="#handleProfile"/>
                    <MenuItem text="📋  Lịch sử"   onAction="#handleHistory"/>
                    <MenuItem fx:id="ordersMenuItem"
                              text="🛒  Đơn hàng"  onAction="#handleOrders"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="🚪  Đăng xuất" onAction="#handleLogout"/>
                </items>
            </MenuButton>
        </HBox>
    </top>

    <!-- ══ CONTENT ══ -->
    <center>
        <StackPane>

            <VBox spacing="16" style="-fx-background-color: #0f172a;">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <Label text="🏷️  Sản phẩm đấu giá hiện tại"
                       style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#e2e8f0;"/>

                <!-- Auction Card (ẩn mặc định) -->
                <HBox fx:id="auctionCard"
                      styleClass="auction-card"
                      spacing="24"
                      visible="false"
                      managed="false">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                    <VBox styleClass="product-image-box" alignment="CENTER" minWidth="220">
                        <Label text="⬡" styleClass="product-image-icon"/>
                        <Label fx:id="statusLabel" styleClass="status-badge"/>
                    </VBox>

                    <VBox spacing="12" HBox.hgrow="ALWAYS">
                        <Label fx:id="productTitleLabel" styleClass="product-title"/>
                        <Label fx:id="productDescLabel"  styleClass="product-desc" wrapText="true"/>

                        <HBox spacing="24">
                            <VBox styleClass="price-cell">
                                <Label text="Giá khởi điểm"    styleClass="price-label"/>
                                <Label fx:id="startPriceLabel" styleClass="price-value"/>
                            </VBox>
                            <VBox styleClass="price-cell price-current">
                                <Label text="Giá hiện tại"       styleClass="price-label"/>
                                <Label fx:id="currentPriceLabel" styleClass="price-current-value"/>
                            </VBox>
                            <VBox styleClass="price-cell">
                                <Label text="Bước giá tối thiểu" styleClass="price-label"/>
                                <Label fx:id="minStepLabel"      styleClass="price-value"/>
                            </VBox>
                            <VBox styleClass="price-cell">
                                <Label text="Kết thúc lúc"  styleClass="price-label"/>
                                <Label fx:id="endTimeLabel" styleClass="price-value"/>
                            </VBox>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="24">
                            <VBox>
                                <Label text="THỜI GIAN CÒN LẠI" styleClass="countdown-label"/>
                                <HBox spacing="4" alignment="CENTER_LEFT">
                                    <VBox alignment="CENTER">
                                        <Label fx:id="hoursLabel" text="00" styleClass="countdown-num"/>
                                        <Label text="GIỜ"  styleClass="countdown-unit"/>
                                    </VBox>
                                    <Label text=":" styleClass="countdown-sep"/>
                                    <VBox alignment="CENTER">
                                        <Label fx:id="minsLabel" text="00" styleClass="countdown-num"/>
                                        <Label text="PHÚT" styleClass="countdown-unit"/>
                                    </VBox>
                                    <Label text=":" styleClass="countdown-sep"/>
                                    <VBox alignment="CENTER">
                                        <Label fx:id="secsLabel" text="00" styleClass="countdown-num"/>
                                        <Label text="GIÂY" styleClass="countdown-unit"/>
                                    </VBox>
                                </HBox>
                            </VBox>
                            <Button text="ĐẶT GIÁ NGAY!"
                                    onAction="#handlePlaceBid"
                                    styleClass="btn-bid"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Empty State (hiện mặc định) -->
                <VBox fx:id="emptyAuctionBox"
                      styleClass="auction-card"
                      alignment="CENTER"
                      spacing="12"
                      prefHeight="200"
                      visible="true"
                      managed="true">
                    <padding><Insets top="36" right="40" bottom="36" left="40"/></padding>
                    <Label text="🏷️"
                           style="-fx-font-size:48px;"/>
                    <Label text="Chưa có phiên đấu giá nào đang diễn ra"
                           style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:#94a3b8;"/>
                    <Label text="Khi có sản phẩm được đăng, thông tin sẽ hiển thị tại đây."
                           style="-fx-font-size:13px; -fx-text-fill:#64748b;"
                           wrapText="true"/>
                </VBox>

                <!-- Lịch sử bid -->
                <VBox styleClass="info-card" VBox.vgrow="ALWAYS" spacing="8">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="Lịch sử bid" styleClass="card-title"/>
                    <Separator/>
                    <ScrollPane fitToWidth="true" prefHeight="200" styleClass="bid-scroll">
                        <VBox fx:id="bidHistoryBox" spacing="6"/>
                    </ScrollPane>
                    <Hyperlink text="Xem tất cả lịch sử →"
                               onAction="#handleHistory"
                               styleClass="see-all-link"/>
                </VBox>
            </VBox>

            <!-- Chat FAB -->
            <Button text="💬"
                    onAction="#handleToggleChat"
                    styleClass="btn-chat-fab"
                    StackPane.alignment="BOTTOM_RIGHT">
                <StackPane.margin><Insets bottom="24" right="24"/></StackPane.margin>
            </Button>

            <!-- Chat Panel -->
            <VBox fx:id="chatPanel"
                  styleClass="chat-panel"
                  spacing="0"
                  prefWidth="340" maxWidth="340" maxHeight="480"
                  StackPane.alignment="BOTTOM_RIGHT"
                  visible="false" managed="false">
                <StackPane.margin><Insets bottom="88" right="16"/></StackPane.margin>

                <HBox styleClass="chat-header" alignment="CENTER_LEFT" spacing="8">
                    <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                    <Label text="💬 CHAT TRỰC TUYẾN" styleClass="chat-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="onlineCountLabel" text="● Online ..." styleClass="chat-online"/>
                    <Button text="✕" onAction="#handleToggleChat" styleClass="btn-close-chat"/>
                </HBox>

                <ScrollPane fx:id="chatScrollPane"
                            fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            prefHeight="360"
                            styleClass="chat-scroll">
                    <VBox fx:id="chatMessagesBox" spacing="8">
                        <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                    </VBox>
                </ScrollPane>

                <HBox styleClass="chat-input-row" spacing="8" alignment="CENTER">
                    <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
                    <TextField fx:id="chatInput"
                               promptText="Nhập tin nhắn..."
                               HBox.hgrow="ALWAYS"
                               styleClass="chat-input"
                               onAction="#handleSendChat"/>
                    <Button text="➤" onAction="#handleSendChat" styleClass="btn-send"/>
                </HBox>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
